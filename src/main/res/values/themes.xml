<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Equipos" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/surface_container_low_light</item>
        <item name="materialButtonStyle">@style/Widget.Equipos.Button.Sport</item>
    </style>

    <style name="Widget.Equipos.Button.Sport" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/grass_green</item>
        <item name="rippleColor">@color/black_12</item>
        <item name="strokeColor">@color/outline_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">2dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="iconTint">@color/black</item>
    </style>
</resources>